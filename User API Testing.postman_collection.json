    {
      "name": "Email validation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"All users have valid email structure (contains @)\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    \r",
              "    // Check if response is an array\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "    \r",
              "    // Validate each user's email\r",
              "    jsonData.forEach((user, index) => {\r",
              "        pm.expect(user, `User at index ${index}`).to.have.property(\"email\");\r",
              "        \r",
              "        let email = user.email;\r",
              "        pm.expect(email, `User ${index} email: ${email}`).to.include(\"@\");\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
